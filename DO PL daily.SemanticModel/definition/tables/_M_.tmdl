	measure Visits_Dyn_AC =
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period],MAX(SinglePeriod[Period]))
			VAR PeriodLength = SELECTEDVALUE(PeriodsFilter[ID])
			var AggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var delta=SELECTEDVALUE(SelectAggrLength[Value])
			var CDate=SELECTEDVALUE(Periods[Period])
			RETURN if(CDate >= SelectedDate - PeriodLength + 1 && CDate <= SelectedDate,
			    SWITCH(AggrType,
			            "Daily",CALCULATE([VisitsFactMeasure]),
			            "YTD",TOTALYTD([VisitsFactMeasure],Periods[Period],All(Periods)),
			            "MTD",TOTALMTD([VisitsFactMeasure],Periods[Period],All(Periods)),
			            "MQT",CALCULATE([VisitsFactMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-90,DAY)),
			            "MMT",CALCULATE([VisitsFactMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-30,DAY)),
			            "MAT",CALCULATE([VisitsFactMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1,YEAR)),
			            "Custom",CALCULATE([VisitsFactMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1*delta,DAY))
			    )
			    ,BLANK()
			)
		formatString: 0
		lineageTag: 30983a4c-5011-4ee6-90f8-9e24c108e9cb

	measure Visits_Dyn_PY = ```
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period], MAX(SinglePeriod[Period]))
			VAR PeriodLength = SELECTEDVALUE(PeriodsFilter[ID])
			var AggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var delta=SELECTEDVALUE(SelectAggrLength[Value])
			var CDate=SELECTEDVALUE(Periods[Period])
			VAR PYMaxDate = LOOKUPVALUE(Periods[DatePY], Periods[Period], MAX(Periods[Period]))
			VAR PYMinDate = PYMaxDate - delta + 1 
			return if(CDate >= SelectedDate - PeriodLength + 1 && CDate <= SelectedDate,
			    SWITCH(AggrType,
			        "Daily",CALCULATE([VisitsFactMeasure],ALL(Periods),TREATAS(VALUES(Periods[DatePY]),Periods[Period])),
			        "YTD",TOTALYTD([VisitsFactMeasure], DATEADD(Periods[Period], -1, YEAR), ALL(Periods)),
			        "MTD",TOTALMTD([VisitsFactMeasure], DATEADD(Periods[Period], -1, YEAR), ALL(Periods)),
			        "MQT",CALCULATE([VisitsFactMeasure],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-90,DAY),-1,YEAR)),
			        "MMT",CALCULATE([VisitsFactMeasure],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-30,DAY),-1,YEAR)),
			        "MAT",CALCULATE([VisitsFactMeasure],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1,YEAR),-1,YEAR)),
			        "Custom",CALCULATE([VisitsFactMeasure],All(Periods),Periods[Period]>=PYMinDate && Periods[Period]<=PYMaxDate)
			     ),BLANK()
			)
			```
		formatString: 0
		lineageTag: e81037ac-c0e4-43a7-a354-dae4b957f7f0

