table _M_
	isHidden
	lineageTag: 376233a7-99f2-445f-85b4-443c59febd8b

	measure SumByMeasure =
			
			var measureType=SELECTEDVALUE(SelectMeasures[MeasureName])
			var curType=SELECTEDVALUE(_CURRENCY_[_CURRENCY_])
			return SWITCH(TRUE(),
			        measureType="pcs",sum(Data[Q]),
			        measureType in {curType,curType&"/tabs",curType&"/DDD"},sum(Data[V]),
			        measureType in {"USD","USD/tabs","USD/DDD"},sum(Data[V_USD]),
			        measureType in {"EUR","EUR/tabs","EUR/DDD"},sum(Data[V_EUR]),
			        measureType="tabs",sum(Data[TABS]),
			        measureType="DDD",sum(Data[DDD])
			    )
		isHidden
		lineageTag: 4c4680de-7511-435b-be0b-12f24ce4f1f7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Distr_Sales_Dyn_AC =
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period],MAX(SinglePeriod[Period]))
			VAR PeriodLength = SELECTEDVALUE(PeriodsFilter[ID])
			var AggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var delta=SELECTEDVALUE(SelectAggrLength[Value])
			var CDate=SELECTEDVALUE(Periods[Period])
			RETURN if(CDate >= SelectedDate - PeriodLength + 1 && CDate <= SelectedDate,
			    SWITCH(AggrType,
			            "Daily",CALCULATE([SumByMeasure]),
			            "YTD",TOTALYTD([SumByMeasure],Periods[Period],All(Periods)),
			            "MTD",TOTALMTD([SumByMeasure],Periods[Period],All(Periods)),
			            "MQT",CALCULATE([SumByMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-90,DAY)),
			            "MMT",CALCULATE([SumByMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-30,DAY)),
			            "MAT",CALCULATE([SumByMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1,YEAR)),
			            "Custom",CALCULATE([SumByMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1*delta,DAY))
			    )
			    ,BLANK()
			)
		isHidden
		lineageTag: bc6a1608-e997-461c-8ede-88ab506e9267

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure RankByVol =
			
			var SelectDim=SELECTEDVALUE('Dimensions'[DimName])
			return if(ISBLANK([Distr_Sales_AC]),1000000,
			    SWITCH(SelectDim,
			        "Corporation",rankx(ALLSELECTED(Drugs[Corporation]),[Distr_Sales_AC],,Desc,Dense),
			        "Market Org",rankx(ALLSELECTED(Drugs[Market Org]),[Distr_Sales_AC],,Desc,Dense),
			        "Brand",rankx(ALLSELECTED(Drugs[Brand]),[Distr_Sales_AC],,Desc,Dense),
			        "Brand+Market Org",rankx(ALLSELECTED(Drugs[Brand+Market Org]),[Distr_Sales_AC],,Desc,Dense),
			        "Brand+Corporation",rankx(ALLSELECTED(Drugs[Brand+Corporation]),[Distr_Sales_AC],,Desc,Dense),
			        "SKU",rankx(ALLSELECTED(Drugs[Full medication name]),[Distr_Sales_AC],,Desc,Dense),
			        "INN",rankx(ALLSELECTED(Drugs[INN]),[Distr_Sales_AC],,Desc,Dense),
			        "Comp group L1",IF(ISBLANK(SELECTEDVALUE(Groups[PRODUCT_NAME_TREE.1])),1000000,RANKX(FILTER(ALLSELECTED(Groups[PRODUCT_NAME_TREE.1]),NOT ISBLANK(Groups[PRODUCT_NAME_TREE.1])),[Distr_Sales_AC],,Desc,Dense)),
			        "Comp group L2",IF(ISBLANK(SELECTEDVALUE(Groups[PRODUCT_NAME_TREE.2])),1000000,RANKX(FILTER(ALLSELECTED(Groups[PRODUCT_NAME_TREE.2]),NOT ISBLANK(Groups[PRODUCT_NAME_TREE.2])),[Distr_Sales_AC],,Desc,Dense)),
			        "Comp group L3",IF(ISBLANK(SELECTEDVALUE(Groups[PRODUCT_NAME_TREE.3])),1000000,RANKX(FILTER(ALLSELECTED(Groups[PRODUCT_NAME_TREE.3]),NOT ISBLANK(Groups[PRODUCT_NAME_TREE.3])),[Distr_Sales_AC],,Desc,Dense)),
			        "Comp group L4",IF(ISBLANK(SELECTEDVALUE(Groups[PRODUCT_NAME_TREE.4])),1000000,RANKX(FILTER(ALLSELECTED(Groups[PRODUCT_NAME_TREE.4]),NOT ISBLANK(Groups[PRODUCT_NAME_TREE.4])),[Distr_Sales_AC],,Desc,Dense)),
			        "Comp group L5",IF(ISBLANK(SELECTEDVALUE(Groups[PRODUCT_NAME_TREE.5])),1000000,RANKX(FILTER(ALLSELECTED(Groups[PRODUCT_NAME_TREE.5]),NOT ISBLANK(Groups[PRODUCT_NAME_TREE.5])),[Distr_Sales_AC],,Desc,Dense)),
			        "Category",rankx(ALLSELECTED(Drugs[CategoryLongName]),[Distr_Sales_AC],,Desc,Dense),
