	measure Paginated_Top_Dyn_SKU =
			
			var currentPage=SELECTEDVALUE(SelectPagesDyn[Value])
			var itemsPerPage=[TOP]
			var beginTop=itemsPerPage*(currentPage-1)+1
			var endTop=itemsPerPage*currentPage
			var pagesCount=QUOTIENT(DISTINCTCOUNT(Drugs[Full medication name]),itemsPerPage)+1
			var s="Top {FROM}..{TO}, page {PAGE} of {PAGES}"
			var ss=CALCULATE(SELECTEDVALUE(T[dst],s),T[src]=s)
			return SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(ss,"{FROM}",beginTop),"{TO}",endTop),"{PAGE}",currentPage),"{PAGES}",pagesCount)
		isHidden
		lineageTag: 6285e170-b3c8-4962-a550-da3fc8396553

