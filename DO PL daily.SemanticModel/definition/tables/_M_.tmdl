	measure Distr_Dyn_AC =
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period],MAX(SinglePeriod[Period]))
			VAR PeriodLength = SELECTEDVALUE(PeriodsFilter[ID])
			var AggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var delta=SELECTEDVALUE(SelectAggrLength[Value])
			var CDate=SELECTEDVALUE(Periods[Period])
			RETURN if(CDate >= SelectedDate - PeriodLength + 1 && CDate <= SelectedDate,
			    SWITCH(AggrType,
			            "Daily",CALCULATE([DistrSumMeasure]),
			            "YTD",TOTALYTD([DistrSumMeasure],Periods[Period],All(Periods)),
			            "MTD",TOTALMTD([DistrSumMeasure],Periods[Period],All(Periods)),
			            "MQT",CALCULATE([DistrSumMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-90,DAY)),
			            "MMT",CALCULATE([DistrSumMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-30,DAY)),
			            "MAT",CALCULATE([DistrSumMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1,YEAR)),
			            "Custom",CALCULATE([DistrSumMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1*delta,DAY))
			    )
			    ,BLANK()
			)
		lineageTag: 43286fb2-6da2-4a92-83a4-7ccf3694c8a9

	measure DistrPlanByMeasure =
			
			var measureType=SELECTEDVALUE(SelectMeasures[MeasureName])
			var curType=SELECTEDVALUE(_CURRENCY_[_CURRENCY_])
			return SWITCH(TRUE(),
			        measureType="pcs",sum(DataPlan[Q]),
			        measureType in {curType,curType&"/tabs",curType&"/DDD"},sum(DataPlan[V]),
			        measureType in {"USD","USD/tabs","USD/DDD"},sum(DataPlan[V_USD]),
			        measureType in {"EUR","EUR/tabs","EUR/DDD"},sum(DataPlan[V_EUR]),
			        measureType="tabs",sum(DataPlan[TABS]),
			        measureType="DDD",sum(DataPlan[DDD])
			    )
		lineageTag: 04d516fc-5d7a-4354-b736-bd4e83d3e926

		annotation PBI_FormatHint = {"isGeneralNumber":true}

