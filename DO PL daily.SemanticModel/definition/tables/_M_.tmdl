			        "Brand+Corporation",rankx(ALLSELECTED(Drugs[Brand+Corporation]),ROUND([Visits_AC],4),,Desc,Dense),
			        "SKU",rankx(ALLSELECTED(Drugs[Full medication name]),ROUND([Visits_AC],4),,Desc,Dense),
			        "INN",rankx(ALLSELECTED(Drugs[INN]),ROUND([Visits_AC],4),,Desc,Dense),
