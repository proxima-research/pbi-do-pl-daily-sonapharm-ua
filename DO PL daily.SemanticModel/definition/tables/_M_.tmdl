	measure SumByMeasure_PriceDivider =
			
			var measureType=SELECTEDVALUE(SelectMeasures[MeasureName])
			var curType=SELECTEDVALUE(_CURRENCY_[_CURRENCY_])
			return SWITCH(TRUE(),
			        measureType in {"pcs",curType,"USD","EUR"},sum(Data[Q]),
			        measureType in {curType&"/tabs","USD/tabs","EUR/tabs"},sum(Data[TABS]),
			        measureType in {curType&"/DDD","USD/DDD","EUR/DDD"},sum(Data[DDD]),
