	measure Stock_Clients_Count_Total_Dyn_AC =
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period], MAX(SinglePeriod[Period]))
			VAR PeriodLength = SELECTEDVALUE(PeriodsFilter[ID])
			VAR AggrType = SELECTEDVALUE(Aggr[AGGR_TYPE])
			VAR delta = SELECTEDVALUE(SelectAggrLength[Value])
			VAR CDate = SELECTEDVALUE(Periods[Period])
			RETURN
			IF(
			    CDate >= SelectedDate - PeriodLength + 1 && CDate <= SelectedDate,
			    SWITCH(
			        AggrType,
			        "Daily",
			            CALCULATE(
			                DISTINCTCOUNT(StockClientsPeriods[CLIENT_ID])
			            ),
			        "YTD",
			            TOTALYTD(
			                DISTINCTCOUNT(StockClientsPeriods[CLIENT_ID]),
			                Periods[Period],
			                ALL(Periods)
			            ),
			        "MTD",
			            TOTALMTD(
			                DISTINCTCOUNT(StockClientsPeriods[CLIENT_ID]),
			                Periods[Period],
			                ALL(Periods)
			            ),
			        "MQT",
			            CALCULATE(
			                DISTINCTCOUNT(StockClientsPeriods[CLIENT_ID]),
			                ALL(Periods),
			                DATESINPERIOD(Periods[Period], LASTDATE(Periods[Period]), -90, DAY)
			            ),
			        "MMT",
			            CALCULATE(
			                DISTINCTCOUNT(StockClientsPeriods[CLIENT_ID]),
			                ALL(Periods),
			                DATESINPERIOD(Periods[Period], LASTDATE(Periods[Period]), -30, DAY)
			            ),
			        "MAT",
			            CALCULATE(
			                DISTINCTCOUNT(StockClientsPeriods[CLIENT_ID]),
			                ALL(Periods),
			                DATESINPERIOD(Periods[Period], LASTDATE(Periods[Period]), -1, YEAR)
			            ),
			        "Custom",
			            CALCULATE(
			                DISTINCTCOUNT(StockClientsPeriods[CLIENT_ID]),
			                ALL(Periods),
			                DATESINPERIOD(Periods[Period], LASTDATE(Periods[Period]), -1 * delta, DAY)
			            )
			    ),
			    BLANK()
			)
		formatString: 0
		lineageTag: cc2b71eb-b282-4d8a-8fb5-aaf13a9ad338

