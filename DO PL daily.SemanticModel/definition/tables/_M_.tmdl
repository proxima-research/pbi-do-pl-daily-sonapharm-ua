	measure Distr_Sales_Dyn_PY_WO_Window = ```
			
			var AggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var delta=SELECTEDVALUE(SelectAggrLength[Value])
			VAR PYMaxDate = LOOKUPVALUE(Periods[DatePY], Periods[Period], MAX(Periods[Period]))
			VAR PYMinDate = PYMaxDate - delta + 1 
			return  SWITCH(AggrType,
			        "Daily",CALCULATE([SumByMeasure],ALL(Periods),TREATAS(VALUES(Periods[DatePY]),Periods[Period])),
			        "YTD",TOTALYTD([SumByMeasure], DATEADD(Periods[Period], -1, YEAR), ALL(Periods)),
			        "MTD",TOTALMTD([SumByMeasure], DATEADD(Periods[Period], -1, YEAR), ALL(Periods)),
			        "MQT",CALCULATE([SumByMeasure],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-90,DAY),-1,YEAR)),
			        "MMT",CALCULATE([SumByMeasure],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-30,DAY),-1,YEAR)),
			        "MAT",CALCULATE([SumByMeasure],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1,YEAR),-1,YEAR)),
			        "Custom",CALCULATE([SumByMeasure],All(Periods),Periods[Period]>=PYMinDate && Periods[Period]<=PYMaxDate)
			     )
			
			```
		lineageTag: 659fda7e-a1b7-4977-baf7-1fc027356858

		annotation PBI_FormatHint = {"isGeneralNumber":true}

