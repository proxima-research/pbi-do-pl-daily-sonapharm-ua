			var AggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var delta=SELECTEDVALUE(SelectAggrLength[Value])
			var CDate=SELECTEDVALUE(Periods[Period])
			RETURN if(CDate >= SelectedDate - PeriodLength + 1 && CDate <= SelectedDate,
			    SWITCH(AggrType,
			            "Daily",CALCULATE([VisitsPlanByMeasure]),
			            "YTD",TOTALYTD([VisitsPlanByMeasure],Periods[Period],All(Periods)),
			            "MTD",TOTALMTD([VisitsPlanByMeasure],Periods[Period],All(Periods)),
			            "MQT",CALCULATE([VisitsPlanByMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-90,DAY)),
			            "MMT",CALCULATE([VisitsPlanByMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-30,DAY)),
			            "MAT",CALCULATE([VisitsPlanByMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1,YEAR)),
			            "Custom",CALCULATE([VisitsPlanByMeasure],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1*delta,DAY))
			    )
			    ,BLANK()
			)
