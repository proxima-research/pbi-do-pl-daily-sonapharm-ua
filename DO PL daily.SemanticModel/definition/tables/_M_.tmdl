	measure Market_Sales_PPY =
			CALCULATE([Distr_Sales_Dyn_PPY],
			    Filter(Periods,
			        IF(ISFILTERED(Periods[Period]),Periods[setperiod]>0,
			        if(ISFILTERED(SinglePeriod),
			            Periods[setperiod] in values(SinglePeriod[PERIOD_ID]),
			            Periods[setperiod]=max(SinglePeriod[PERIOD_ID]))
			        )
			    )
			)
		isHidden
