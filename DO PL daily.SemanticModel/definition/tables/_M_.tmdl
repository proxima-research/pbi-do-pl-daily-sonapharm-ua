	measure RankByPRT =
			
			var SelectDim=SELECTEDVALUE('Dimensions'[DimName])
			return if(ISBLANK([PRT_AC]),1000000,
			    SWITCH(SelectDim,
			        "Corporation",rankx(ALLSELECTED(Drugs[Corporation]),[PRT_AC],,Desc,Dense),
			        "Market Org",rankx(ALLSELECTED(Drugs[Market Org]),[PRT_AC],,Desc,Dense),
			        "Brand",rankx(ALLSELECTED(Drugs[Brand]),[PRT_AC],,Desc,Dense),
			        "Brand+Market Org",rankx(ALLSELECTED(Drugs[Brand+Market Org]),[PRT_AC],,Desc,Dense),
			        "Brand+Corporation",rankx(ALLSELECTED(Drugs[Brand+Corporation]),[PRT_AC],,Desc,Dense),
			        "SKU",rankx(ALLSELECTED(Drugs[Full medication name]),[PRT_AC],,Desc,Dense),
			        "INN",rankx(ALLSELECTED(Drugs[INN]),[PRT_AC],,Desc,Dense),
			        "Comp group L1",IF(ISBLANK(SELECTEDVALUE(Groups[PRODUCT_NAME_TREE.1])),1000000,RANKX(FILTER(ALLSELECTED(Groups[PRODUCT_NAME_TREE.1]),NOT ISBLANK(Groups[PRODUCT_NAME_TREE.1])),[PRT_AC],,Desc,Dense)),
			        "Comp group L2",IF(ISBLANK(SELECTEDVALUE(Groups[PRODUCT_NAME_TREE.2])),1000000,RANKX(FILTER(ALLSELECTED(Groups[PRODUCT_NAME_TREE.2]),NOT ISBLANK(Groups[PRODUCT_NAME_TREE.2])),[PRT_AC],,Desc,Dense)),
			        "Comp group L3",IF(ISBLANK(SELECTEDVALUE(Groups[PRODUCT_NAME_TREE.3])),1000000,RANKX(FILTER(ALLSELECTED(Groups[PRODUCT_NAME_TREE.3]),NOT ISBLANK(Groups[PRODUCT_NAME_TREE.3])),[PRT_AC],,Desc,Dense)),
			        "Comp group L4",IF(ISBLANK(SELECTEDVALUE(Groups[PRODUCT_NAME_TREE.4])),1000000,RANKX(FILTER(ALLSELECTED(Groups[PRODUCT_NAME_TREE.4]),NOT ISBLANK(Groups[PRODUCT_NAME_TREE.4])),[PRT_AC],,Desc,Dense)),
