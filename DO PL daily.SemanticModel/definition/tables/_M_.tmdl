	measure Distr_Stock_Dyn_PWD =
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period], MAX(SinglePeriod[Period]))
			VAR PeriodLength = SELECTEDVALUE(PeriodsFilter[ID])
			VAR AggrType = SELECTEDVALUE(Aggr[AGGR_TYPE])
			VAR Delta = SELECTEDVALUE(SelectAggrLength[Value])
			VAR CDate = SELECTEDVALUE(Periods[Period])
			
			VAR PWDMaxDate = CDate - 7
			VAR PWDMinDate = PWDMaxDate - Delta + 1
			
			RETURN
			IF(
			    CDate >= SelectedDate - PeriodLength + 1 && CDate <= SelectedDate,
			    SWITCH(
			        AggrType,
			        "Daily",
			            CALCULATE(
			                [SumStockByMeasure],
			                ALL(Periods),
			                Periods[Period] = CDate - 7
			            ),
			        "YTD",
			            CALCULATE(
			                [SumStockByMeasure],
			                ALL(Periods),
			                DATESYTD(DATEADD(Periods[Period], -7, DAY))
			            ),
			        "MTD",
			            CALCULATE(
			                [SumStockByMeasure],
			                ALL(Periods),
			                DATESMTD(DATEADD(Periods[Period], -7, DAY))
			            ),
			        "MQT",
			            CALCULATE(
			                [SumStockByMeasure],
			                ALL(Periods),
			                DATEADD(
			                    DATESINPERIOD(Periods[Period], LASTDATE(Periods[Period]), -90, DAY),
			                    -7,
			                    DAY
			                )
			            ),
			        "MMT",
			            CALCULATE(
			                [SumStockByMeasure],
			                ALL(Periods),
			                DATEADD(
			                    DATESINPERIOD(Periods[Period], LASTDATE(Periods[Period]), -30, DAY),
			                    -7,
			                    DAY
			                )
			            ),
			        "MAT",
			            CALCULATE(
			                [SumStockByMeasure],
			                ALL(Periods),
			                DATEADD(
			                    DATESINPERIOD(Periods[Period], LASTDATE(Periods[Period]), -1, YEAR),
			                    -7,
			                    DAY
			                )
			            ),
			        "Custom",
			            CALCULATE(
			                [SumStockByMeasure],
			                ALL(Periods),
			                Periods[Period] >= PWDMinDate &&
			                Periods[Period] <= PWDMaxDate
			            )
			    ),
			    BLANK()
			)
		lineageTag: f770417b-f052-49d2-9298-84aae881b4ff

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Distr_Stock_PWD =
			CALCULATE([Distr_Stock_Dyn_PWD],
			    Filter(Periods,
			        IF(ISFILTERED(Periods[Period]),Periods[setperiod]>0,
			        if(ISFILTERED(SinglePeriod),
			            Periods[setperiod] in values(SinglePeriod[PERIOD_ID]),
			            Periods[setperiod]=max(SinglePeriod[PERIOD_ID]))
