	measure Years_Range =
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period],MAX(SinglePeriod[Period]))
			VAR PeriodLength = SELECTEDVALUE(PeriodsFilter[ID])
			var minYear=CALCULATE(min(Periods[Year]),filter(Periods,Periods[Period]>=SelectedDate - PeriodLength + 1))
			var maxYear=CALCULATE(max(Periods[Year]),filter(Periods,Periods[Period]<=SelectedDate))
			return if(minYear=maxYear,minYear,minYear&".."&maxYear)
