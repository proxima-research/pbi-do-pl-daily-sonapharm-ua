	measure TOTAL = ```
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period], MAX(SinglePeriod[Period]))
			VAR AggrType = SELECTEDVALUE(Aggr[AGGR_TYPE])
			VAR delta = SELECTEDVALUE(SelectAggrLength[Value])
			
			RETURN
			    SWITCH(
			        AggrType,
			        "Daily", 
			            CALCULATE(
			                [SumByMeasure],
			                Periods[Period] = SelectedDate,
			                REMOVEFILTERS(Periods)
			            ),
			        "YTD", 
			            CALCULATE(
			                TOTALYTD([SumByMeasure], Periods[Period], ALL(Periods)),
			                Periods[Period] <= SelectedDate,
			                REMOVEFILTERS(Periods)
			            ),
			        "MTD", 
			            CALCULATE(
			                TOTALMTD([SumByMeasure], Periods[Period], ALL(Periods)),
			                Periods[Period] <= SelectedDate,
			                REMOVEFILTERS(Periods)
			            ),
			        "MQT", 
			            CALCULATE(
			                [SumByMeasure], 
			                ALL(Periods),
			                DATESINPERIOD(Periods[Period], SelectedDate, -90, DAY)
			            ),
			        "MMT", 
			            CALCULATE(
			                [SumByMeasure], 
			                ALL(Periods),
			                DATESINPERIOD(Periods[Period], SelectedDate, -30, DAY)
			            ),
			        "MAT", 
			            CALCULATE(
			                [SumByMeasure], 
			                ALL(Periods),
			                DATESINPERIOD(Periods[Period], SelectedDate, -1, YEAR)
			            ),
			        "Custom", 
			            CALCULATE(
			                [SumByMeasure], 
			                ALL(Periods),
			                DATESINPERIOD(Periods[Period], SelectedDate, -1 * delta, DAY)
			            ),
			        BLANK()
			    )
			
			```
		isHidden
		lineageTag: 9efcef57-748b-48fd-a8f7-80cafb8759cc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

