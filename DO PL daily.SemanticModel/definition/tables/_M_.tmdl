	measure Market_Sales_PriceDivider_Dyn_AC =
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period],MAX(SinglePeriod[Period]))
			VAR PeriodLength = SELECTEDVALUE(PeriodsFilter[ID])
			var AggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var delta=SELECTEDVALUE(SelectAggrLength[Value])
			var CDate=SELECTEDVALUE(Periods[Period])
			RETURN if(CDate >= SelectedDate - PeriodLength + 1 && CDate <= SelectedDate,
			    SWITCH(AggrType,
			            "Daily",CALCULATE([SumByMeasure_PriceDivider]),
			            "YTD",TOTALYTD([SumByMeasure_PriceDivider],Periods[Period],All(Periods)),
			            "MTD",TOTALMTD([SumByMeasure_PriceDivider],Periods[Period],All(Periods)),
			            "MQT",CALCULATE([SumByMeasure_PriceDivider],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-90,DAY)),
			            "MMT",CALCULATE([SumByMeasure_PriceDivider],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-30,DAY)),
			            "MAT",CALCULATE([SumByMeasure_PriceDivider],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1,YEAR)),
			            "Custom",CALCULATE([SumByMeasure_PriceDivider],All(Periods),DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1*delta,DAY))
			    )
			    ,BLANK()
			)
		isHidden
		lineageTag: 9ed37499-9ef4-4d50-97e3-87161b1326b2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Market_Sales_PriceDivider_Dyn_PY = ```
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period],MAX(SinglePeriod[Period]))
			VAR PeriodLength = SELECTEDVALUE(PeriodsFilter[ID])
			var AggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var delta=SELECTEDVALUE(SelectAggrLength[Value])
			var CDate=SELECTEDVALUE(Periods[Period])
			VAR PYMaxDate = LOOKUPVALUE(Periods[DatePY], Periods[Period], MAX(Periods[Period]))
			VAR PYMinDate = PYMaxDate - delta + 1 
			return if(CDate >= SelectedDate - PeriodLength + 1 && CDate <= SelectedDate,
			    SWITCH(AggrType,
			        "Daily",CALCULATE([SumByMeasure_PriceDivider],ALL(Periods),TREATAS(VALUES(Periods[DatePY]),Periods[Period])),
			        "YTD",TOTALYTD([SumByMeasure_PriceDivider], DATEADD(Periods[Period], -1, YEAR), ALL(Periods)),
			        "MTD",TOTALMTD([SumByMeasure_PriceDivider], DATEADD(Periods[Period], -1, YEAR), ALL(Periods)),
			        "MQT",CALCULATE([SumByMeasure_PriceDivider],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-90,DAY),-1,YEAR)),
			        "MMT",CALCULATE([SumByMeasure_PriceDivider],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-30,DAY),-1,YEAR)),
			        "MAT",CALCULATE([SumByMeasure_PriceDivider],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1,YEAR),-1,YEAR)),
			        "Custom",CALCULATE([SumByMeasure_PriceDivider],All(Periods),Periods[Period]>=PYMinDate && Periods[Period]<=PYMaxDate)
			     ),BLANK()
			)
			```
		isHidden
		lineageTag: a0b3e30e-8cc2-4d84-81d2-ab2d86ea6d04

		annotation PBI_FormatHint = {"isGeneralNumber":true}

