	measure Selected_Periods_List = ```
			
			var isFilteredPeriods=ISFILTERED(Periods[Period])
			var isMultiPeriods=CALCULATE(DISTINCTCOUNT(Periods[Period]),Filter(Periods,Periods[Year]=[Current_Year]))>1
			var isFilteredSinglePeriods=ISFILTERED(SinglePeriod)
			var isMultiSinglePeriods=DISTINCTCOUNT(SinglePeriod[Period])>1
			return 
			if(isFilteredPeriods,
			        // for select in Periods table
			        if(isMultiPeriods,
			            CALCULATE(CONCATENATEX(Periods,Periods[Period],","),Filter(Periods,Periods[Year]=[Current_Year])),
			            CALCULATE(Format(max(Periods[Period]),"dd.mm.yyyy"),Filter(Periods,Periods[Year]=[Current_Year]))
			        ),
			        // for select in SinglePeriod table
			        if(isFilteredSinglePeriods,
			            if(isMultiSinglePeriods,
			                CONCATENATEX(SinglePeriod,Format(SinglePeriod[Period],"dd.mm.yyyy"),","),Format(max(SinglePeriod[Period]),"dd.mm.yyyy")
			            ), 
			            // else by default
			            Format(max(SinglePeriod[Period]),"dd.mm.yyyy")
			        )
			)
			```
		formatString: 0
		isHidden
		lineageTag: ce24eb56-3a2d-4f4a-9f44-a8c1d383fa58

