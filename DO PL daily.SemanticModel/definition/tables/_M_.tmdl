		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Distr_Sales_Dyn_PPY =
			
			VAR SelectedDate = SELECTEDVALUE(SinglePeriod[Period], MAX(SinglePeriod[Period]))
			VAR PeriodLength = SELECTEDVALUE(PeriodsFilter[ID])
			VAR DeltaWeekDay = WEEKDAY(SelectedDate, 2) - WEEKDAY(EDATE(SelectedDate, -12), 2)
			var AggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var delta=SELECTEDVALUE(SelectAggrLength[Value])
			var CDate=SELECTEDVALUE(Periods[Period])
			RETURN if(CDate >= SelectedDate - PeriodLength + 1 && CDate <= SelectedDate,
			    SWITCH(AggrType,
			        "Daily",CALCULATE([SumByMeasure],ALL(Periods),DATEADD(DATEADD(Periods[Period],-2,YEAR),DeltaWeekDay,DAY)),
			        "YTD", Calculate(TOTALYTD([SumByMeasure], Periods[Period], ALL(Periods)),DATEADD(Periods[Period],-2,YEAR)),
			        "MTD",Calculate(TOTALMTD([SumByMeasure], Periods[Period], ALL(Periods)),DATEADD(Periods[Period],-2,YEAR)),
			        "MQT",CALCULATE([SumByMeasure],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-90,DAY),-2,YEAR)),
			        "MMT",CALCULATE([SumByMeasure],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-30,DAY),-2,YEAR)),
			        "MAT",CALCULATE([SumByMeasure],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-2,YEAR),-2,YEAR)),
			        "Custom",CALCULATE([SumByMeasure],All(Periods),DATEADD(DATESINPERIOD(Periods[Period],LASTDATE(Periods[Period]),-1*delta,DAY),-2,YEAR))
			    ),BLANK()
			)
		isHidden
		lineageTag: 6d9aa56b-4db2-44e4-bcfc-4c415a0d8dc2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

