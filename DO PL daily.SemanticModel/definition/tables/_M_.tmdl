			        "Comp Group L2",IF(ISBLANK(SELECTEDVALUE(Groups[PRODUCT_NAME_TREE.2])),1000000,RANKX(FILTER(ALLSELECTED(Groups[PRODUCT_NAME_TREE.2]),NOT ISBLANK(Groups[PRODUCT_NAME_TREE.2])),ROUND([Distr_Stock_AC],4),,DESC, Dense)),
