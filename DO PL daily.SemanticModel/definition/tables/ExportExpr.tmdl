	partition ExportExpr = calculated
		mode: import
		source =
				
				var curName=SELECTEDVALUE(_CURRENCY_[_CURRENCY_])
				return {
				    ("Distr sales, "&curName, NAMEOF('_M_'[SumByVol_AC_AllPeriods]), 0),
				    ("Distr sales, "&"USD", NAMEOF('_M_'[SumByUSD_AC_AllPeriods]), 1),
				    ("Distr sales, "&"EUR", NAMEOF('_M_'[SumByEUR_AC_AllPeriods]), 2),
				    ("Distr sales, "&"pcs", NAMEOF('_M_'[SumByPCS_AC_AllPeriods]), 3),
				    ("Distr sales, "&"tabs", NAMEOF('_M_'[SumByTABS_AC_AllPeriods]), 4),
				    ("Distr sales, "&"DDD", NAMEOF('_M_'[SumByDDD_AC_AllPeriods]), 5)
				}

	annotation PBI_Id = 401e6ff8d3e14c21acfffbe11abed201

