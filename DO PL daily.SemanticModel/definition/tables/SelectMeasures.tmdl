	partition SelectMeasures = calculated
		mode: import
		source =
				
				var CTable=DATATABLE("MeasureName",STRING,"MeasureSign",STRING,"id",INTEGER,"MeasureNameFull",STRING,"FOR_PRICE_PAGE",INTEGER,"FOR_NOT_PRICE_PAGE",INTEGER,
				    {
				        {"USD","$",2,"USD",1,1},
				        {"EUR","€",3,"EUR",1,1},
				        {"pcs","pcs",4,"Packs",0,1},
				        {"tabs","tabs",5,"Tabs",0,1},
				        {"DDD","DDD",6,"DDD",0,1},
				        {"USD/tabs","tabsUSD",301,"tabsUSD",1,0},
				        {"EUR/tabs","tabsEUR",302,"TabsEUR",1,0},
				        {"USD/DDD","DDDUSD",401,"DDDUSD",1,0},
				        {"EUR/DDD","DDDEUR",402,"DDDEUR",1,0}
				    }
				)
				var Currency_Name=SELECTEDVALUE(_CURRENCY_[_CURRENCY_])
				var FullCTable=UNION(
				        ROW("MeasureName",Currency_Name,"MeasureSign",Currency_Name,"id",1,"MeasureNameFull",Currency_Name,"FOR_PRICE_PAGE",1,"FOR_NOT_PRICE_PAGE",1),
				        ROW("MeasureName",Currency_Name&"/tabs","MeasureSign","tabs"&Currency_Name,"id",300,"MeasureNameFull","tabs"&Currency_Name,"FOR_PRICE_PAGE",1,"FOR_NOT_PRICE_PAGE",0),
				        ROW("MeasureName",Currency_Name&"/DDD","MeasureSign","DDD"&Currency_Name,"id",400,"MeasureNameFull","DDD"&Currency_Name,"FOR_PRICE_PAGE",1,"FOR_NOT_PRICE_PAGE",0),
				        CTable
				    )
				return FullCTable

	annotation PBI_Id = aa0800d001774997b60c2f0ae65b5573

