	measure Header_Dynamic_By_Dim_Main =
			
			var measureName=SELECTEDVALUE(SelectMeasures[MeasureName])
			var aggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var selectedDim=SELECTEDVALUE('Dimensions'[DimName])
			var s="{DATA_TYPE} market {EXPR} in {MEASURE} by {DIM_NAME}"
			var e=SWITCH(SELECTEDVALUE(SelectExpr[ExprType]),"SO","sales","MS","MS%","EI","EI")
			var ss=CALCULATE(SELECTEDVALUE(T[dst],s),T[src]=s)
			var ee=CALCULATE(SELECTEDVALUE(T[dst],e),T[src]=e)
			var sss=SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(ss,"{DATA_TYPE}",[Current_Data_Type]),"{EXPR}",ee),"{MEASURE}",measureName),"{DIM_NAME}",selectedDim)
			return sss&", "&aggrType&", "&[Years_List]
		isHidden
		lineageTag: 79006849-4566-4a48-9761-7aa2e370f356

