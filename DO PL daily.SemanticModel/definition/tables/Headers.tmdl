	measure Header_Export_Main =
			
			var isShowData=[IsExportFieldSelected]+[IsExportExprSelected]
			var aggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var fields=if([IsExportFieldSelected]>0,CONCATENATEX(VALUES(ExportFields[ExportFieldName]),ExportFields[ExportFieldName],", "),BLANK())
			var s=switch(isShowData,
			    0,"Please select at least one value in 'Export fields' and 'Export measures' selectоrs",
			    1,"Please select at least one value in 'Export measures' selectоr",
			    2,"Please select at least one value in 'Export fields' selectоr",
			    3,"Export data, by {FIELDS}"
			)
			var ss=CALCULATE(SELECTEDVALUE(T[dst],s),T[src]=s)
			return if(isShowData=3,SUBSTITUTE(SUBSTITUTE(ss,"{DATA_TYPE}",[Current_Data_Type]),"{FIELDS}",fields)&", "&aggrType&", "&[Years_List],ss)
		isHidden
		lineageTag: 48030bdf-585c-4b7f-b2d1-3452778bb14b

