	measure Header_Rating_Main =
			
			var dimName=SELECTEDVALUE('Dimensions'[DimName])
			var measureName=SELECTEDVALUE(SelectMeasures[MeasureName])
			var aggrType=SELECTEDVALUE(Aggr[AGGR_TYPE])
			var periodName=[Selected_Periods_List]
			var s="{DATA_TYPE} market sales in {MEASURE}, by {DIM_NAME}"
			var ss=CALCULATE(SELECTEDVALUE(T[dst],s),T[src]=s)
			var sss=SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(ss,"{DATA_TYPE}",[Current_Data_Type]),"{DIM_NAME}",dimName),"{MEASURE}",measureName)
			return sss&", "&aggrType&", "&periodName
		isHidden
		lineageTag: 6a8a1da1-4133-425a-9b4e-a2f19a53bdf7

