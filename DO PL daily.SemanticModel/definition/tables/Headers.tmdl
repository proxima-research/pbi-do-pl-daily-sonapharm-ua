	measure Header_Dynamic_Ecom_Main =
			
			var measureName=SELECTEDVALUE(SelectMeasures[MeasureName])
			var aggrType=SELECTEDVALUE(Periods[AGGR_TYPE])
			var dimName=SELECTEDVALUE('Dimensions'[DimName])
			var expr=SELECTEDVALUE(SelectExprOnlineOffline[OnlineExprType])
			var s1="Online {DATA_TYPE} sales"
			var s2="Offline {DATA_TYPE} sales"
			var s3="Online {DATA_TYPE} sales in total {DATA_TYPE} sales"
			var e=SWITCH(expr,"Online",s1,"Offline",s2,"MS",s3)
			var ee=CALCULATE(SELECTEDVALUE(T[dst],e),T[src]=e)
			var eee=SUBSTITUTE(ee,"{DATA_TYPE}",[Current_Data_Type_SM])
			var s="{EXPR_TYPE} in {MEASURE}, by {DIM_NAME}"
			var ss=CALCULATE(SELECTEDVALUE(T[dst],s),T[src]=s)
			return SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(ss,"{EXPR_TYPE}",eee),"{MEASURE}",measureName),"{DIM_NAME}",dimName)&", "&[Years_List]&", "&aggrType
		isHidden
		lineageTag: eb5058d9-ae5a-4930-9e41-ca3d6ac1b870

