	column Disabled
		formatString: 0
		lineageTag: 2cb4e527-6554-4c3b-94a4-f8b80ffaa3ea
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Disabled]

		annotation SummarizationSetBy = Automatic

	partition SelectSelfMO = calculated
		mode: import
		source =
				
				var MO=distinct(SELECTCOLUMNS(Drugs,"Market Org",Drugs[Market Org],"Market Org ID",Drugs[Market Org ID],"UserCulture",Drugs[UserCulture],"Disabled",0))
				var disableMO=DATATABLE("Market Org",STRING,"Market Org ID",INTEGER,"J",STRING,"Disabled",INTEGER,{{"-- Disable --",0,"1",1}})
				var defaultMO=DATATABLE("Market Org",STRING,"Market Org ID",INTEGER,"J",STRING,"Disabled",INTEGER,{{"-- Default --",0,"1",0}})
				var languages=ADDCOLUMNS(SELECTCOLUMNS(SelectLanguages,"UserCulture",SelectLanguages[UserCulture]),"J","1")
				var disableMOAndLang=NATURALLEFTOUTERJOIN(disableMO,languages)
				var disableMOAndLangDone=SELECTCOLUMNS(disableMOAndLang,[Market Org],[Market Org ID],[UserCulture],[Disabled])
				var defaultMOAndLang=NATURALLEFTOUTERJOIN(defaultMO,languages)
				var defaultMOAndLangDone=SELECTCOLUMNS(defaultMOAndLang,[Market Org],[Market Org ID],[UserCulture],[Disabled])
				return Union(MO,defaultMOAndLangDone,disableMOAndLangDone)

	annotation PBI_Id = 8bdb61e2ce104a44aa1cdb993a44be05

